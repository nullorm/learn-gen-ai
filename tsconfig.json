{
  "compilerOptions": {
    "target": "ESNext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": false,
    "types": ["bun-types"]
  },
  "include": ["src/**/*.ts", "tools/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
